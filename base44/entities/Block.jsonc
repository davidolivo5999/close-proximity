{
  "name": "Block",
  "type": "object",
  "properties": {
    "blocker_id": {
      "type": "string",
      "description": "The user who initiated the block"
    },
    "blocked_id": {
      "type": "string",
      "description": "The user who was blocked"
    }
  },
  "required": [
    "blocker_id",
    "blocked_id"
  ],
  "rls": {
    "create": {
      "data.blocker_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.blocker_id": "{{user.id}}"
        },
        {
          "data.blocked_id": "{{user.id}}"
        }
      ]
    },
    "update": {
      "data.blocker_id": "{{user.id}}"
    },
    "delete": {
      "data.blocker_id": "{{user.id}}"
    }
  }
}